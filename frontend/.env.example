# Base URL of the FastAPI backend.
# Leave empty in local dev (Vite proxies /api to http://127.0.0.1:8000).
# In production (Vercel), set this to your deployed backend.
VITE_API_BASE_URL=

# Dev server port (default 5173). Use with npm run dev for LAN sharing.
# Example: VITE_DEV_PORT=8080
VITE_DEV_PORT=
